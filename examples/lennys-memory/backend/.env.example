# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# OpenAI Configuration
OPENAI_API_KEY=sk-...

# Provider Configuration (v0.3+)
# Default is OpenAI for both. To run on Anthropic + local sentence-
# transformers (no OpenAI dependency), set:
#   LLM_MODEL=anthropic/claude-3-5-sonnet-latest
#   EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
#   ANTHROPIC_API_KEY=sk-ant-...
# See docs: how-to/bring-your-own-model
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small
# ANTHROPIC_API_KEY=sk-ant-...

# Entity Enrichment Configuration
# Automatically enrich entities with data from Wikipedia and Diffbot
ENRICHMENT_ENABLED=true
# Optional: Diffbot API key for richer entity data
# DIFFBOT_API_KEY=your-diffbot-api-key

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000
